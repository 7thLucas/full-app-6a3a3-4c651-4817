_KEYSPACE=keyspace
_USER_ID=1234
MONGODB_URI=mongodb://localhost:27017/your_app_name

QB_SCAFFOLDER_KEY=your_api_auth_key

# Billing (Stripe). Leave STRIPE_SECRET_KEY unset to run billing in MOCK mode
# (checkout upgrades the user instantly, no Stripe account needed). Set all of
# these to enable real subscription checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
# App base URL used to build Stripe checkout return links (e.g. https://app.example.com).
APP_URL=
